import React, { useEffect, useRef } from 'react';
import Hls from 'hls.js';

const VideoPlayer = () => {
  const videoRef = useRef(null);
  
  // Replace these with your actual stream requirements
  const rawM3u8Url = 'YOUR_M3U8_STREAM_URL_HERE';
  const requiredReferer = 'YOUR_REQUIRED_REFERER_URL_HERE';

  // Route the request through your local Express proxy
  const proxyUrl = `http://localhost:5000/proxy/stream?url=${encodeURIComponent(rawM3u8Url)}&referer=${encodeURIComponent(requiredReferer)}`;

  useEffect(() => {
    const video = videoRef.current;
    if (!video) return;

    let hls;

    if (Hls.isSupported()) {
      hls = new Hls();
      hls.loadSource(proxyUrl);
      hls.attachMedia(video);
      hls.on(Hls.Events.MANIFEST_PARSED, () => {
        video.play().catch(e => console.log('Autoplay prevented', e));
      });
    } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
      // Native HLS support (Safari)
      video.src = proxyUrl;
      video.addEventListener('loadedmetadata', () => {
        video.play();
      });
    }

    return () => {
      if (hls) {
        hls.destroy();
      }
    };
  }, [proxyUrl]);

  return (
    <div style={{ maxWidth: '800px', margin: '0 auto' }}>
      <h2>Proxied M3U8 Player</h2>
      <video
        ref={videoRef}
        controls
        style={{ width: '100%', aspectRatio: '16/9', backgroundColor: '#000' }}
      />
    </div>
  );
};

export default VideoPlayer;

